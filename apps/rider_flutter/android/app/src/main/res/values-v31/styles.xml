<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/splash_color</item>
        <!-- We set this to a transparent drawable or just let it default, 
             but setting it to splash_color effectively hides the icon on many devices -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
